{
  "manifest_version": 3,
  "name": "保存网页并发送给deepseek或千问",
  "version": "2.1",
  "description": "保存任意网页HTML并在DeepSeek、通义千问等AI平台批量上传分析",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://*.qianwen.com/*",
    "https://*.qwen.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "保存网页并发送给deepseek或千问",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["deepseek-content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.qianwen.com/*",
        "https://*.qwen.ai/*"
      ],
      "js": ["qianwen-uploader.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
